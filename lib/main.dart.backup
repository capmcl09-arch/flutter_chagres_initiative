            style: Theme.of(context).textTheme.headlineSmall?.copyWith(
              color: Colors.white,
            ),
          ),
          const SizedBox(height: 12),
          Text(
            language == 'en'
                ? 'Ongoing field reflections, research updates, and official project documentation from the Chagres Initiative.'
